
<div class="row justify-content-center">
    <div class="col-xl-6 col-lg-12 col-md-9">
        <div class="card o-hidden border-0 shadow-lg my-5">
            <div class="card-body p-0">
                <!-- Nested Row within Card Body -->
                <div class="row">
                    <!--<div class="col-lg-5 d-none d-lg-block bg-register-image"></div>-->
            

            
                    <div class="col-lg-3"></div>
                    <div class="col-lg-6">
                        <div class="p-6">
                            <div class="text-center">
                                <h1 class="h4 text-gray-900 mb-5 align-items-center"><%= __('addcategory') %></h1>
                                <% if (locals.validation_error!=undefined) { %>
                                    <%- include('./partials/_mesaj')  %>
                                <% } %>
                            </div>
                            <form class="user" 
                                action= "<%= typeof selectedCategory != 'undefined' 
                                    ? '/editcategory/' + categoryId  
                                    : '/addnewcategory' %>" 
                                method="post">

                                <div class="d-flex align-items-center" style="margin-right:2rem;">
                                    <label for="dil" class="me-2"><%= __('language') %></label>
                                    <div class="arrow">
                                        <select name="dil" id="dil" class="bg-light" >                                            
                                            <option value="en" <%= typeof selectedCategory != 'undefined' && selectedCategory.dil==='en' ? 'selected' : ''%>>en</option>                                        
                                            <option value="tr" <%= typeof selectedCategory === 'undefined' || selectedCategory.dil==='tr' ? 'selected' : ''%>>tr</option>
                                        </select>
                                    </div>
                                </div>


                                <br>
                                    <div class="col-sm-6 mb-3 mb-sm-0">
                                        <input type="text" value="<%= typeof selectedCategory != 'undefined' ? selectedCategory.kategori : ''%>" name="kategori" class="form-control form-control-user" id="exampleFirstName"
                                            placeholder="<%= __('kategori') %>">
                                    </div>
                                    <br>
                                    <div class="col-sm-9">
                                        <input type="text" value="<%= typeof selectedCategory != 'undefined' ? selectedCategory.aciklama : ''%>" name="aciklama" class="form-control form-control-user" id="exampleLastName"
                                            placeholder="<%= __('aciklama') %>">
                                    </div>                                    
                                
                                <br>
                                </div>
                                <br>
                                
                                <div class="form-group row">
                                    <div class="col-sm-3">
                                        <!-- Kaydet (POST) -->
                                        <button type="submit" name="action" value="save" class="btn btn-primary ">
                                            <%= __('save') %>
                                        </button>
                                    </div>

                                    <div class="col-sm-3">
                                        <a href="/category"  class="btn btn-secondary">
                                            <%= __('cancel') %>
                                        </a>
                                    </div>
                                </div>                         
                            
                                <!--
                                <hr>
                                <a href="index.html" class="btn btn-google btn-user btn-block">
                                    <i class="fab fa-google fa-fw"></i> Register with Google
                                </a>
                                <a href="index.html" class="btn btn-facebook btn-user btn-block">
                                    <i class="fab fa-facebook-f fa-fw"></i> Register with Facebook
                                </a>
                                -->
                            </form>                            
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>